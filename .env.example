# 环境变量配置文件
# 复制此文件为 .env 并修改相应值

# Flask配置
SECRET_KEY=your-secret-key-here

# 数据库配置
DATABASE_URL=sqlite:///fund_management.db
# PostgreSQL示例:
# DATABASE_URL=postgresql://username:password@localhost/fund_management

# 外部API配置（可选）
EASTMONEY_API_TIMEOUT=10
EASTMONEY_API_CACHE_TTL=3600

# 应用配置
DEBUG=True
PORT=5000
HOST=0.0.0.0